# ============================================================================
# .env.vespera.example — Template for Vespera runtime credentials
# ----------------------------------------------------------------------------
# This file IS committed (no real secrets). Copy to `.env.vespera` locally
# and fill VESPERA_DB_PASSWORD with the value issued by Dara after the
# `create-sentinel-ro.sql` migration is applied.
#
# Story: T002.0a
# Owner: Dara (@data-engineer), co-signed by Riven (@risk-manager, R10)
# ============================================================================

# --- Sentinel TimescaleDB (read-only role) ---
VESPERA_DB_HOST=localhost
VESPERA_DB_PORT=5433
VESPERA_DB_NAME=sentinel_db
VESPERA_DB_USER=sentinel_ro
VESPERA_DB_PASSWORD=<replace-with-value-from-dara>

# --- Hold-out lock (R1 + R15(d)) ---
# Default fail-closed. `0` blocks any read of timestamps in
# [2025-07-01, 2026-04-21]. Never set to `1` inside the T002.0 epic.
VESPERA_UNLOCK_HOLDOUT=0
